{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/session-start.sh\"",
          "timeout": 5
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/work-tracker.sh\" prompt"
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/security-guard.sh\"",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "mcp__*",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/rate-limiter.sh\"",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash|WebFetch|WebSearch",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/secret-filter.sh\"",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/slop-detector.sh\"",
          "timeout": 5
        },
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/post-edit.sh\""
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/work-tracker.sh\" stop"
        },
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/verify-gate.sh\""
        },
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/session-wrap.sh\""
        }
      ]
    }
  ],
  "TaskCompleted": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "bash \"$CLAUDE_PROJECT_DIR/hooks/task-completed.sh\"",
          "timeout": 10
        }
      ]
    }
  ]
}
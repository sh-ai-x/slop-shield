{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 14,
  "permissions": {
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Glob(./**)",
      "Grep(./**)",
      "Bash(python3:*)",
      "Bash(bash:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Task(*)",
      "Skill(*)",
      "AskUserQuestion(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskGet(*)",
      "TaskList(*)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(rm -rf ~)*",
      "Bash(rm -rf .)*",
      "Bash(rm -rf *)*",
      "Bash(sudo:*)",
      "Bash(chmod 777:*)",
      "Bash(curl*|*sh)*",
      "Bash(wget*|*sh)*",
      "Bash(*>~/.ssh/*)",
      "Bash(*>~/.zshrc)*",
      "Bash(git push --force*main)*",
      "Bash(git push --force*master)*",
      "Bash(git reset --hard origin/*)*",
      "Bash(git clean -f*)*",
      "Bash(npm publish)*",
      "Bash(docker system prune)*",
      "Bash(eval:*)",
      "Bash(bash -c:*)",
      "Bash(sh -c:*)",
      "Bash(osascript:*)",
      "Bash(crontab:*)",
      "Bash(launchctl:*)"
    ]
  }
}